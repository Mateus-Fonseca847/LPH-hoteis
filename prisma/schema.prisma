generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id               String                @id @default(cuid())
  name             String
  slug             String                @unique
  shortDescription String
  fullDescription  String                @db.Text
  city             String
  state            String
  address          String
  phone            String
  email            String
  whatsapp         String
  coverImageUrl    String
  checkInTime      String
  checkOutTime     String
  latitude         Decimal?              @db.Decimal(10, 7)
  longitude        Decimal?              @db.Decimal(10, 7)
  isPublished      Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  images           HotelImage[]
  rooms            HotelRoom[]
  amenities        HotelAmenity[]
  policies         HotelPolicy[]
  permissions      HotelPermission[]
  auditLogs        HotelAuditLog[]
  reservations     Reservation[]
  paymentSettings  HotelPaymentSettings?

  @@index([slug])
  @@index([city])
  @@index([state])
  @@index([city, state])
  @@index([isPublished])
}

model HotelRoom {
  id               String             @id @default(cuid())
  hotelId          String
  name             String
  description      String             @db.Text
  imageUrl         String
  capacity         Int
  capacityAdults   Int                @default(1)
  capacityChildren Int                @default(0)
  beds             String
  size             String
  sizeM2           Int?
  amenities        String[]           @default([])
  priceFrom        Decimal            @db.Decimal(10, 2)
  isAvailable      Boolean            @default(true)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  hotel            Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rates            RoomRate[]
  availability     RoomAvailability[]
  reservations     Reservation[]

  @@index([hotelId])
  @@index([hotelId, isActive])
  @@index([hotelId, isAvailable])
}

model RoomRate {
  id                String    @id @default(cuid())
  roomId            String
  name              String
  description       String    @db.Text
  priceCents        Int
  currency          String    @default("BRL")
  startDate         DateTime
  endDate           DateTime
  minNights         Int       @default(1)
  maxGuests         Int
  refundable        Boolean   @default(false)
  breakfastIncluded Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  room              HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([roomId, isActive])
  @@index([roomId, startDate, endDate])
}

model RoomAvailability {
  id             String    @id @default(cuid())
  roomId         String
  date           DateTime
  totalUnits     Int
  availableUnits Int
  closed         Boolean   @default(false)
  note           String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  room           HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([roomId])
  @@index([date])
  @@index([closed])
}

model HotelImage {
  id        String   @id @default(cuid())
  hotelId   String
  url       String
  alt       String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model HotelAmenity {
  id        String   @id @default(cuid())
  hotelId   String
  label     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model HotelPolicy {
  id          String   @id @default(cuid())
  hotelId     String
  title       String
  description String   @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model User {
  id                    String            @id @default(cuid())
  name                  String
  email                 String            @unique
  passwordHash          String
  globalRole            GlobalRole        @default(user)
  isActive              Boolean           @default(true)
  emailVerifiedAt       DateTime?
  emailTwoFactorEnabled Boolean           @default(false)
  twoFactorEnabled      Boolean           @default(false)
  twoFactorSecret       String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  hotelPermissions      HotelPermission[]
  auditLogs             HotelAuditLog[]
  emailAuthCodes        EmailAuthCode[]

  @@index([globalRole])
  @@index([isActive])
  @@index([createdAt])
}

model EmailAuthCode {
  id        String               @id @default(cuid())
  userId    String
  codeHash  String
  purpose   EmailAuthCodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int                  @default(0)
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@index([userId, purpose, expiresAt])
}

model HotelPermission {
  id        String    @id @default(cuid())
  userId    String
  hotelId   String
  role      HotelRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
  @@index([userId])
  @@index([hotelId])
  @@index([hotelId, role])
}

model HotelAuditLog {
  id            String   @id @default(cuid())
  userId        String
  hotelId       String
  action        String
  changedFields Json?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hotelId])
  @@index([createdAt])
  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
}

model Reservation {
  id                      String            @id @default(cuid())
  hotelId                 String
  roomId                  String
  guestName               String
  guestEmail              String
  guestPhone              String
  guestDocument           String?
  checkIn                 DateTime
  checkOut                DateTime
  adults                  Int
  children                Int               @default(0)
  nights                  Int
  nightlyPriceCents       Int
  totalPriceCents         Int
  currency                String            @default("BRL")
  status                  ReservationStatus @default(pending)
  paymentProvider         PaymentProvider?
  paymentMethod           String?
  paymentStatus           PaymentStatus     @default(pending)
  providerPaymentId       String?           @unique
  stripeCheckoutSessionId String?           @unique
  stripePaymentIntentId   String?
  paidAt                  DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  hotel                   Hotel             @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  room                    HotelRoom         @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([hotelId])
  @@index([roomId])
  @@index([status])
  @@index([paymentProvider])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([hotelId, createdAt])
  @@index([guestEmail])
}

model HotelPaymentSettings {
  id                   String          @id @default(cuid())
  hotelId              String          @unique
  provider             PaymentProvider @default(manual)
  isEnabled            Boolean         @default(false)
  receiverLabel        String
  publicKey            String?
  encryptedAccessToken String?
  pixKey               String?
  payoutDocument       String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  hotel                Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([isEnabled])
}

enum GlobalRole {
  super_admin
  hotel_admin
  user
}

enum HotelRole {
  owner
  admin
  editor
}

enum EmailAuthCodePurpose {
  login_2fa
  email_verification
  password_reset
}

enum ReservationStatus {
  pending
  awaiting_payment
  confirmed
  paid
  payment_failed
  cancelled
}

enum PaymentProvider {
  manual
  mercado_pago
}

enum PaymentStatus {
  pending
  awaiting_payment
  paid
  payment_failed
  cancelled
}
