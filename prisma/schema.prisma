generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id                        String                     @id @default(cuid())
  name                      String
  slug                      String                     @unique
  shortDescription          String
  fullDescription           String                     @db.Text
  city                      String
  state                     String
  address                   String
  phone                     String
  email                     String
  whatsapp                  String
  coverImageUrl             String
  checkInTime               String
  checkOutTime              String
  latitude                  Decimal?                   @db.Decimal(10, 7)
  longitude                 Decimal?                   @db.Decimal(10, 7)
  isPublished               Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  images                    HotelImage[]
  rooms                     HotelRoom[]
  amenities                 HotelAmenity[]
  policies                  HotelPolicy[]
  permissions               HotelPermission[]
  auditLogs                 HotelAuditLog[]
  reservations              Reservation[]
  paymentTransactions       PaymentTransaction[]
  paymentReconciliationLogs PaymentReconciliationLog[]
  reservationOperationLogs  ReservationOperationLog[]
  paymentSettings           HotelPaymentSettings?

  @@index([slug])
  @@index([city])
  @@index([state])
  @@index([city, state])
  @@index([isPublished])
}

model HotelRoom {
  id               String             @id @default(cuid())
  hotelId          String
  name             String
  description      String             @db.Text
  imageUrl         String
  capacity         Int
  capacityAdults   Int                @default(1)
  capacityChildren Int                @default(0)
  beds             String
  size             String
  sizeM2           Int?
  amenities        String[]           @default([])
  priceFrom        Decimal            @db.Decimal(10, 2)
  isAvailable      Boolean            @default(true)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  hotel            Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rates            RoomRate[]
  availability     RoomAvailability[]
  reservations     Reservation[]

  @@index([hotelId])
  @@index([hotelId, isActive])
  @@index([hotelId, isAvailable])
}

model RoomRate {
  id                String    @id @default(cuid())
  roomId            String
  name              String
  description       String    @db.Text
  priceCents        Int
  currency          String    @default("BRL")
  startDate         DateTime
  endDate           DateTime
  minNights         Int       @default(1)
  maxGuests         Int
  refundable        Boolean   @default(false)
  breakfastIncluded Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  room              HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([roomId, isActive])
  @@index([roomId, startDate, endDate])
}

model RoomAvailability {
  id             String    @id @default(cuid())
  roomId         String
  date           DateTime
  totalUnits     Int
  availableUnits Int
  closed         Boolean   @default(false)
  note           String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  room           HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([roomId])
  @@index([date])
  @@index([closed])
}

model HotelImage {
  id        String   @id @default(cuid())
  hotelId   String
  url       String
  alt       String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model HotelAmenity {
  id        String   @id @default(cuid())
  hotelId   String
  label     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model HotelPolicy {
  id          String   @id @default(cuid())
  hotelId     String
  title       String
  description String   @db.Text
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, position])
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  passwordHash             String
  globalRole               GlobalRole                @default(user)
  isActive                 Boolean                   @default(true)
  emailVerifiedAt          DateTime?
  /// Controls the current login 2FA flow by e-mail.
  emailTwoFactorEnabled    Boolean                   @default(false)
  /// Legacy authenticator-app/TOTP flag. It does not control the current login flow.
  twoFactorEnabled         Boolean                   @default(false)
  /// Legacy authenticator-app/TOTP secret.
  twoFactorSecret          String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  hotelPermissions         HotelPermission[]
  auditLogs                HotelAuditLog[]
  reservationOperationLogs ReservationOperationLog[]
  emailAuthCodes           EmailAuthCode[]

  @@index([globalRole])
  @@index([isActive])
  @@index([createdAt])
}

model EmailAuthCode {
  id        String               @id @default(cuid())
  userId    String
  codeHash  String
  purpose   EmailAuthCodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int                  @default(0)
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@index([userId, purpose, expiresAt])
}

model HotelPermission {
  id        String    @id @default(cuid())
  userId    String
  hotelId   String
  role      HotelRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelId])
  @@index([userId])
  @@index([hotelId])
  @@index([hotelId, role])
}

model HotelAuditLog {
  id            String   @id @default(cuid())
  userId        String
  hotelId       String
  action        String
  changedFields Json?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hotelId])
  @@index([createdAt])
  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
}

model Reservation {
  id                        String                     @id @default(cuid())
  hotelId                   String
  roomId                    String
  guestName                 String
  guestEmail                String
  guestPhone                String
  guestDocument             String?
  checkIn                   DateTime
  checkOut                  DateTime
  adults                    Int
  children                  Int                        @default(0)
  nights                    Int
  nightlyPriceCents         Int
  totalPriceCents           Int
  currency                  String                     @default("BRL")
  status                    ReservationStatus          @default(pending)
  paymentProvider           PaymentProvider?
  paymentMethod             String?
  paymentStatus             PaymentStatus              @default(pending)
  providerPaymentId         String?                    @unique
  stripeCheckoutSessionId   String?                    @unique
  stripePaymentIntentId     String?
  paidAt                    DateTime?
  expiresAt                 DateTime?
  expiredAt                 DateTime?
  availabilityHeld          Boolean                    @default(false)
  isTestData                Boolean                    @default(false)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  hotel                     Hotel                      @relation(fields: [hotelId], references: [id], onDelete: Restrict)
  room                      HotelRoom                  @relation(fields: [roomId], references: [id], onDelete: Restrict)
  paymentTransaction        PaymentTransaction?
  paymentReconciliationLogs PaymentReconciliationLog[]
  operationLogs             ReservationOperationLog[]

  @@index([hotelId])
  @@index([roomId])
  @@index([status])
  @@index([paymentProvider])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([expiresAt])
  @@index([expiredAt])
  @@index([availabilityHeld])
  @@index([status, expiresAt])
  @@index([isTestData])
  @@index([createdAt])
  @@index([hotelId, createdAt])
  @@index([guestEmail])
}

model PaymentTransaction {
  id                  String          @id @default(cuid())
  reservationId       String          @unique
  hotelId             String
  provider            PaymentProvider
  providerPaymentId   String?         @unique
  paymentMethod       String?
  status              PaymentStatus
  grossAmountCents    Int
  platformFeeCents    Int
  hotelNetAmountCents Int
  currency            String          @default("BRL")
  paidAt              DateTime?
  isTestData          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  reservation         Reservation     @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  hotel               Hotel           @relation(fields: [hotelId], references: [id], onDelete: Restrict)

  @@index([hotelId])
  @@index([provider])
  @@index([providerPaymentId])
  @@index([paymentMethod])
  @@index([status])
  @@index([isTestData])
  @@index([paidAt])
  @@index([createdAt])
  @@index([hotelId, paidAt])
  @@index([hotelId, status, paidAt])
}

model PaymentReconciliationLog {
  id            String          @id @default(cuid())
  reservationId String?
  hotelId       String?
  provider      PaymentProvider @default(mercado_pago)
  source        String
  paymentId     String?
  preferenceId  String?
  remoteStatus  String?
  success       Boolean         @default(false)
  error         String?         @db.Text
  createdAt     DateTime        @default(now())
  reservation   Reservation?    @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  hotel         Hotel?          @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([hotelId])
  @@index([provider])
  @@index([source])
  @@index([remoteStatus])
  @@index([success])
  @@index([createdAt])
}

model ReservationOperationLog {
  id                    String      @id @default(cuid())
  reservationId         String
  hotelId               String
  createdById           String
  action                String
  reason                String      @db.Text
  previousStatus        String?
  nextStatus            String?
  previousPaymentStatus String?
  nextPaymentStatus     String?
  metadata              Json?
  createdAt             DateTime    @default(now())
  reservation           Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  hotel                 Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdBy             User        @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([reservationId])
  @@index([hotelId])
  @@index([createdById])
  @@index([action])
  @@index([createdAt])
}

model HotelPaymentSettings {
  id                   String          @id @default(cuid())
  hotelId              String          @unique
  provider             PaymentProvider @default(manual)
  isEnabled            Boolean         @default(false)
  receiverLabel        String
  publicKey            String?
  encryptedAccessToken String?
  pixKey               String?
  payoutDocument       String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  hotel                Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([isEnabled])
}

model MarketingSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  source          String
  isActive        Boolean   @default(true)
  consentAccepted Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  unsubscribedAt  DateTime?

  @@index([source])
  @@index([isActive])
  @@index([createdAt])
}

enum GlobalRole {
  super_admin
  hotel_admin
  user
}

enum HotelRole {
  owner
  admin
  editor
}

enum EmailAuthCodePurpose {
  login_2fa
  email_verification
  password_reset
}

enum ReservationStatus {
  pending
  awaiting_payment
  confirmed
  paid
  payment_failed
  cancelled
  expired
}

enum PaymentProvider {
  manual
  mercado_pago
}

enum PaymentStatus {
  pending
  awaiting_payment
  paid
  payment_failed
  cancelled
}
