# Banco de dados
# PostgreSQL do ambiente. Codifique caracteres especiais da senha na URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Autenticação
# Segredo forte para assinar sessões e códigos de 2FA por e-mail.
AUTH_SECRET=""

# Chave base64 de 32 bytes para segredos de 2FA. Gere com: openssl rand -base64 32
TWO_FACTOR_ENCRYPTION_KEY=""

# Definido pela plataforma em deploy. Em staging e produção, use production.
NODE_ENV="production"

# Upload
# local grava em public/uploads e exige disco persistente em staging/produção.
# external_url bloqueia novos uploads até integrar S3, R2 ou Supabase Storage.
UPLOAD_MAX_IMAGE_SIZE_BYTES="5242880"
UPLOAD_STORAGE_PROVIDER="local"

# E-mail
EMAIL_PROVIDER="resend"
EMAIL_FROM="LPH Testes <onboarding@resend.dev>"
RESEND_API_KEY=""

# Pagamentos
# URL pública do ambiente usada no retorno do checkout quando a origem da requisição não existir.
NEXT_PUBLIC_APP_URL="https://staging.seu-dominio.com"

# Provedor online ativo. Hoje o código aceita mercado_pago.
PAYMENT_PROVIDER="mercado_pago"

# Aliases genéricos aceitos pelo código. Podem substituir as variáveis MERCADO_PAGO_* equivalentes.
PAYMENT_ACCESS_TOKEN=""
PAYMENT_WEBHOOK_URL=""
PAYMENT_WEBHOOK_SECRET=""

# Chave base64 de 32 bytes para criptografar credenciais de pagamento por hotel.
PAYMENT_SECRETS_ENCRYPTION_KEY=""

# Mercado Pago sandbox/produção. Em staging, use sandbox. Em produção, use credenciais reais somente no provedor de ambiente.
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_SANDBOX="true"
MERCADO_PAGO_WEBHOOK_URL=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# Stripe é legado: manter apenas se for validar compatibilidade do webhook antigo.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Staging / seed
ALLOW_LOCAL_HOTEL_DATA_FALLBACK="false"
SEED_STAGING_SUPER_ADMIN_EMAIL="super.admin.staging@lphhoteis.local"
SEED_STAGING_SUPER_ADMIN_PASSWORD=""
SEED_STAGING_HOTEL_ADMIN_EMAIL="hotel.admin.staging@lphhoteis.local"
SEED_STAGING_HOTEL_ADMIN_PASSWORD=""
SEED_STAGING_HOTEL_ADMIN_HOTEL_SLUG="lph-marina-santos"

# Aliases legados ainda aceitos pelo seed.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
