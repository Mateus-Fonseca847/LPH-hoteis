{
  "name": "lph-hoteis",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src next.config.ts prisma.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality": "npm run format:check && npm run lint && npm run prisma:validate && npm run test && npm run build",
    "start": "next start",
    "finance:test-data": "node scripts/seed-financial-test-data.cjs",
    "finance:clear-test-data": "node scripts/clear-financial-test-data.cjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "next": "^15.5.18",
    "otpauth": "^9.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "prettier": "^3.8.3",
    "prisma": "^6.17.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
